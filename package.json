    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@tsconfig/svelte": "^5.0.8",
    "eslint": "^9.4.1",
    "eslint-plugin-astro": "^0.20.0",
    "prettier": "^3.0.3",
