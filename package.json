{
  "name": "procrasti-net-frontend",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "prestart": "node -e \"if (!require('fs').existsSync('dist/server/entry.mjs')) { console.log('Build missing. Running npm run build...'); require('child_process').execSync('npm run build', {stdio: 'inherit'}); }\"",
    "start": "HOST=0.0.0.0 PORT=3000 node ./dist/server/entry.mjs",    "astro": "astro",
    "lint": "eslint --ext .js,.ts,.astro src",
    "format": "prettier --write '**/*.{js,ts,astro}'",
    "prepare": "husky install || true",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.2",
    "@astrojs/node": "^9.5.4",
    "@astrojs/svelte": "^7.2.5",
    "astro": "^5.16.15",
    "svelte": "^5.53.6",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@tsconfig/svelte": "^5.0.8",
    "eslint": "^9.4.1",
    "eslint-plugin-astro": "^0.20.0",
    "prettier": "^3.0.3",
    "svelte-check": "^4.4.4",
    "typescript": "^5.9.3"
  }
}
