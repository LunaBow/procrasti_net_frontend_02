{
  "name": "Procrasti-net-frontend",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "start": "node ./dist/server/entry.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro",
    "lint": "eslint --ext .js,.ts,.astro src",
    "format": "prettier --write '**/*.{js,ts,astro}'",
    "prepare": "husky install",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.2",
    "@astrojs/node": "^9.5.4",
    "@astrojs/svelte": "^7.2.5",
    "astro": "^5.16.15",
    "svelte": "^5.53.6",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "eslint": "^9.4.1",
    "eslint-plugin-astro": "^0.20.0",
    "husky": "^8.0.3",
    "lint-staged": "^16.3.0",
    "prettier": "^3.0.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run format && npm run lint"
    }
  },
  "lint-staged": {
    "*.{js,ts,astro}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
