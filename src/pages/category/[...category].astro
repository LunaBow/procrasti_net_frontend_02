---
import Header from "../../components/Header.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
import "../../styles/global.css";
import { api } from "../../scripts/API-Client.js";

import SkillCard from "../../components/SkillCard.svelte";

const { category } = Astro.params;


let skills = [];
let categoryName = category;

try {
    const allSkills = await api.listSkills() as any[];
    const allCats = await api.listCategories() as any[];
    
    const catObj = allCats.find((c: any) => c.id == category || c.name.toLowerCase() === category?.toLowerCase());
    if (catObj) {
        categoryName = catObj.name;
        skills = allSkills.filter((s: any) => String(s.category_id) === String(catObj.id));
    } else {
        skills = allSkills.filter((s: any) => String(s.category_id) === String(category));
    }
} catch (e) {
    console.error("Failed to load skills for category:", category, e);
}
---

<div id="entireContentWrapper">
    <Header />
    <Navigation />
    
    <main class="panel">
        <h2>Skills in Category: {categoryName}</h2>
        
        {skills.length === 0 ? (
            <p>No skills found in this category.</p>
        ) : (
            <div class="grid">
                {skills.map((s: any) => (
                    <SkillCard skill={s} />
                ))}
            </div>
        )}
        
        <a href="/Row1/skills" class="btn">Back to Skill Browser</a>
    </main>
    
    <Footer />
</div>

<style>
    main {
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
    }
    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.5rem;
        margin-top: 1.5rem;
    }
    .btn {
        display: inline-block;
        margin-top: 2rem;
        padding: 0.5rem 1rem;
        background: #333;
        color: white;
        text-decoration: none;
        border-radius: 4px;
    }
</style>
