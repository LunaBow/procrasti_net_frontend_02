---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import AuthSvelte from "../components/Auth.svelte";
---
<Layout title="Member Login">
    <div id="entireContentWrapper">
        <Header />
        <Navigation />

        <main class="auth-page">
            <AuthSvelte client:load />
        </main>

        <Footer />
    </div>
</Layout>

<style>
    .auth-page {
        min-height: calc(100vh - 200px); /* adjust if header/footer taller */
        display: grid;
        place-items: center;
        padding: 2rem 1rem;
    }

    .auth-page :global(.auth-card) {
        width: min(420px, 100%);
    }
</style>