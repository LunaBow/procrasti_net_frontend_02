---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import AuthSvelte from "../components/Auth.svelte";
---
<Layout title="Member Login">
    <div id="entireContentWrapper">
        <Header showAuth={false} />
        <Navigation />

        <main class="auth-page">
            <AuthSvelte client:load />
        </main>

        <Footer />
    </div>
</Layout>

<style>
    .auth-page{
        flex: 1;
        display: grid;
        place-items: center;
        padding: 2rem 1rem;
    }

    /* style the actual auth container your Svelte renders */
    .auth-page :global(#AuthVisible){
        max-width: 480px;
    }
</style>