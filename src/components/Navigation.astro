                    <a id="showAVOnly" href="/Row2/art">Multimedia</a>
                    <a id="showBooksOnly" href="/Row2/art">Literary Collection</a>
                </div>
            </div>

            <div class="dropdown-wrapper">
                <a id="TriggerMember" class="dropbtn" href="/Row2/members">The Gang (sheesh)</a>
            </div>


        </nav>

    </div>
</section>

<style>
    .auth-container {
        display: flex;
        justify-content: center;
        width: 100%;
        max-width: 400px;
        padding: 0.5rem;
        margin-bottom: 0.5rem;
        position: relative;
        z-index: 10;
