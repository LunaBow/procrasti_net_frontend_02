        <div class="w-1/3 flex justify-center">
            <AuthSvelte client:load />
        </div>
        <div class="w-1/3 text-right"></div>
    </nav>
    <div id="navWrapper" class="nav-stack">

        <!-- Row 1: core app navigation -->
        <nav class="nav-core" aria-label="Primary navigation">
            <div class="dropdown-wrapper"><a id="triggerSkills" href="/Row1/skills">Skills</a></div>
            <div class="dropdown-wrapper"><a id="triggerTodos" href="/Row1/todos">To-dos</a></div>
            <div class="dropdown-wrapper"><a id="triggerHabits" href="/Row1/habits">Habits</a></div>
            <div class="dropdown-wrapper"><a id="triggerPlanner" href="/Row1/planner">Planner</a></div>
            <div class="dropdown-wrapper"><a id="triggerCalendar" href="/Row1/calendar">Calendar</a></div>
            <div class="dropdown-wrapper"><a id="triggerSettings" href="/Row1/settings">Settings</a></div>

