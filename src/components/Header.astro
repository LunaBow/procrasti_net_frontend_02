<header>
    <details class="auth-drop" id="login-bar">
        <summary>
            <span id="login-status">Not logged in</span>
            <span class="auth-hint">Log in</span>
        </summary>

        <form id="login-form" method="POST" action="#">
            <input type="text" id="username" name="username" placeholder="Username" aria-label="Username" />
            <input type="password" id="password" name="password" placeholder="Password" aria-label="Password" />
            <input type="submit" value="Log in" />
        </form>
    </details>

    <details class="auth-drop" id="register-bar">
        <summary>
            <span class="auth-hint">New here?</span>
            <span class="auth-hint strong">Sign up</span>
        </summary>

        <form id="register-form" method="POST" action="#">
            <input type="text" id="usernameReg" name="usernameReg" placeholder="Username" aria-label="Username" />
            <input type="password" id="passwordReg" name="passwordReg" placeholder="Password" aria-label="Password" />
            <input type="submit" value="Sign up" />
        </form>
    </details>

    <section id="headerHeading">
        <h1>Procrasti-net</h1>
        <div id="theme-switcher">
            <label class="switch">
                <input type="checkbox" id="theme-toggle">
                <span class="slider round"></span>
            </label>
        </div>
    </section>
    <h2> Fuck it, we ball. </h2>
</header>

<script type="module" src="/scripts/switchTheme.js"></script>
<script type="module" src="/scripts/register.js"></script>
<script type="module" src="/scripts/login.js"></script>
<script type="module" src="/scripts/switchContent.js"></script>