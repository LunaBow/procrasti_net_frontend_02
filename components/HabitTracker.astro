<section class="panel">
    <h2>Habits</h2>

    <form id="habitCreate" class="row">
        <label for="habitName" class="sr-only">Habit Name</label>
        <input id="habitName" type="text" placeholder="New habit (e.g. 10-min walk)" required />
        <input type="submit" value="Add" />
    </form>

    <div id="habitList" class="grid"></div>
</section>